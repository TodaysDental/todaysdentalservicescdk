    "@aws-sdk/client-bedrock-agent": "^3.882.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.882.0",
    "@aws-sdk/client-bedrock-runtime": "^3.882.0",
    "@aws-sdk/client-chime-sdk-media-pipelines": "^3.940.0",
    "@aws-sdk/client-chime-sdk-meetings": "^3.864.0",
    "@aws-sdk/client-chime-sdk-voice": "^3.864.0",
    "@aws-sdk/client-cloudformation": "^3.864.0",
